{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "outDir": "./.tsc-cache/web",
    "tsBuildInfoFile": "./.tsc-cache/web.tsbuildinfo",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@renderer/*": ["src/renderer/src/*"],
      "@shared/*": ["src/shared/*"]
    },
    "types": ["vite/client"]
  },
  "include": ["src/renderer/src/**/*", "src/shared/**/*"]
}
